[
  {
    "text": "a ",
    "isBold": true
  },
  {
    "text": "این یک ورزش تیمی است.\n",
    "isBold": false
  },
  {
    "text": "e ",
    "isBold": true
  },
  {
    "text": "شما به توپ از روی تور ضربه می‌زنید.\n",
    "isBold": false
  },
  {
    "text": "i ",
    "isBold": true
  },
  {
    "text": "با توپ بازی می‌شود.\n",
    "isBold": false
  },
  {
    "text": "b. ",
    "isBold": true
  },
  {
    "text": "شما گل می‌زنید.\n",
    "isBold": false
  },
  {
    "text": "f ",
    "isBold": true
  },
  {
    "text": "شما با یک چوب مخصوص (بت) به توپ ضربه می‌زنید.\n",
    "isBold": false
  },
  {
    "text": "j ",
    "isBold": true
  },
  {
    "text": "شما بازیکنان دیگر را مهار می‌کنید (تکل می‌زنید).\n",
    "isBold": false
  },
  {
    "text": "c ",
    "isBold": true
  },
  {
    "text": "یک دروازه‌بان وجود دارد.\n",
    "isBold": false
  },
  {
    "text": "g ",
    "isBold": true
  },
  {
    "text": "شما می‌توانید به صورت انفرادی یا دو نفره بازی کنید.\n",
    "isBold": false
  },
  {
    "text": "k ",
    "isBold": true
  },
  {
    "text": "شما از یک راکت استفاده می‌کنید.\n",
    "isBold": false
  },
  {
    "text": "d ",
    "isBold": true
  },
  {
    "text": "شما کمربندهای رنگی کسب می‌کنید.\n",
    "isBold": false
  },
  {
    "text": "h ",
    "isBold": true
  },
  {
    "text": "شما نباید با توپ بدوید.\n",
    "isBold": false
  },
  {
    "text": "l ",
    "isBold": true
  },
  {
    "text": "شما روی چمن بازی می‌کنید.",
    "isBold": false
  }
]